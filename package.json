{
  "name": "rekord",
  "displayName": "Rekord",
  "description": "Automatically record your dev sessions, checkpoint your code, and generate your entire project history.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rekord.checkpoint",
        "title": "Rekord: Save Checkpoint"
      },
      {
        "command": "rekord.timeline",
        "title": "Rekord: Open Timeline"
      },
      {
        "command": "rekord.setup",
        "title": "Rekord: Setup GitHub Token"
      },
      {
    "command": "rekord.setupAI",
    "title": "Rekord: Setup AI (Gemini)"
      } 
    ],
    "keybindings": [
      {
        "command": "rekord.checkpoint",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      }
      
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@octokit/rest": "^22.0.1"
  }
}
